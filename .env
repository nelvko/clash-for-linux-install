######################################
#
#   全局参数 更改后需 source 本文件后生效 
#
######################################

# 订阅下载超时时间（秒）
CLASHCTL_SUB_TIMEOUT=5

# 订阅下载 UA
CLASHCTL_SUB_UA=mihomo

# 节点延迟测试 URL
CLASHCTL_NODE_DELAY_URL=http://www.gstatic.com/generate_204

# 节点延迟测试超时时间（毫秒）
CLASHCTL_NODE_DELAY_TIMEOUT=5000

# 节点延迟测试 fallback 并发数
CLASHCTL_NODE_DELAY_CONCURRENCY=8

######################################
#
#   以下参数由脚本自动生成，用户无需修改
#
######################################

# 实际安装的内核
CLASHCTL_KERNEL=

# init 系统类型
INIT_TYPE=
