######################################
#
#   用户自定义参数 更改后需 source 本文件后生效 
#
######################################

# 订阅下载超时时间（秒）
CLASHCTL_SUB_TIMEOUT=5

# 订阅下载 UA
CLASHCTL_SUB_UA=mihomo

######################################
#
#   以下参数由脚本自动生成，用户无需修改
#
######################################

# 实际安装的内核
CLASHCTL_KERNEL=

# init 系统类型
INIT_TYPE=

# 部署版本（git 短 SHA），由安装/更新记录，用于 clashctl update 版本比对
CLASHCTL_REV=

# 依赖下载代理与超时（安装时从 .env.install 写入，供 clashctl update 联网使用）
GH_PROXY=
CLASHCTL_DOWNLOAD_TIMEOUT=