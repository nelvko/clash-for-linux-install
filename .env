######################################
#
# 安装前可自定义的配置项
#
######################################

# 安装内核 可选：mihomo、clash
KERNEL_NAME=mihomo

# clashctl 安装路径
CLASHCTL_HOME=~/clashctl

# clashctl 命令路径
CLASHCTL_BIN=${CLASHCTL_HOME}/bin/clashctl

# github 加速
GH_PROXY=https://gh-proxy.org

# 机场订阅
CLASH_CONFIG_URL=

# Web UI 压缩包
ZIP_UI=archives/dist.zip

# 软件版本号
VERSION_MIHOMO=v1.19.17
VERSION_YQ=v4.49.2
VERSION_SUBCONVERTER=v0.9.0
