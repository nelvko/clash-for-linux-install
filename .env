######################################
#
#   参数配置
#
######################################

# 订阅下载 超时时间 单位：秒
CLASHCTL_SUB_TIMEOUT=5

# 订阅下载 UA
CLASHCTL_SUB_UA=mihomo

######################################
#
#   自定义安装配置
#
######################################

# 安装内核 可选：mihomo、clash
CLASHCTL_KERNEL=mihomo

# init系统 （自动检测）
INIT_TYPE=

# clashctl 安装路径
CLASHCTL_HOME=~/clashctl

# github 加速
GH_PROXY=https://gh-proxy.org

# 机场订阅
CLASHCTL_SUB_URL=

# Web UI 压缩包
ZIP_UI=archives/dist.zip

# 软件版本号
VERSION_MIHOMO=v1.19.24
VERSION_YQ=v4.53.2
VERSION_SUBCONVERTER=v0.9.0
