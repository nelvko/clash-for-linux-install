#!/usr/bin/env bash

CLASHCTL_HOME=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd -P)
export CLASHCTL_HOME

. "$CLASHCTL_HOME/.env"

for lib_file in "$CLASHCTL_HOME"/scripts/lib/*.sh; do
    [ -f "$lib_file" ] || continue
    . "$lib_file"
done

clashctl() {
    local subcommand=${1}
    [ $# -gt 0 ] && shift

    case "$subcommand" in
    '' | -h | --help)
        subcommand=help
        ;;
    -* | *[!a-z0-9_-]*)
        _error_quit "Unknown subcommand '$subcommand'"
        ;;
    esac

    local cmd_file="$CLASHCTL_HOME/scripts/cmd/$subcommand.sh"
    [ -f "$cmd_file" ] || {
        _error_quit "Unknown subcommand '$subcommand'" >&2
    }
    . "$cmd_file"
    "clash$subcommand" "$@"
}

clashctl "$@"
